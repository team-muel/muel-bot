{
  "name": "muel-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "mcp:discord": "tsx src/mcpServer.ts",
    "mcp:discord:start": "node dist/mcpServer.js",
    "typecheck": "tsc --noEmit",
    "typecheck:edge": "cd supabase/functions && deno task check",
    "functions:deploy": "supabase functions deploy",
    "db:diff": "supabase db diff",
    "test:regression": "tsx tests/regression/mention-llm-callsite.test.ts",
    "test:regression:research": "tsx tests/regression/research-enrich-callsite.test.ts",
    "test:regression:discord-polish": "tsx tests/regression/discord-output-polish.test.ts",
    "test:regression:delivery": "tsx tests/regression/discord-delivery.test.ts",
    "test:regression:hub-responsiveness": "tsx tests/regression/hub-responsiveness.test.ts",
    "test:regression:channel-buffer": "tsx tests/regression/channel-buffer.test.ts",
    "test:regression:agent-actions": "tsx tests/regression/agent-capability-actions.test.ts",
    "test:regression:context-window": "tsx tests/regression/context-window.test.ts",
    "test:registry": "tsx tests/registry/registry.smoke.test.ts",
    "test:router": "tsx tests/router/router.smoke.test.ts",
    "test:gomdori": "tsx tests/gomdori/phase1-simulation.test.ts && tsx tests/gomdori/w4-runtime-contract.test.ts && tsx tests/gomdori/w6-pasua.test.ts && tsx tests/gomdori/w6-roster.test.ts && tsx tests/gomdori/codex.test.ts && tsx tests/gomdori/v2-abilities.test.ts && tsx tests/gomdori/canon-engine-fidelity.test.ts && tsx tests/gomdori/fullgame-sim.test.ts",
    "sim:balance": "tsx scripts/gomdori-balance-sim.ts",
    "test:smoke": "npm run test:regression && npm run test:regression:research && npm run test:regression:discord-polish && npm run test:regression:delivery && npm run test:regression:hub-responsiveness && npm run test:regression:channel-buffer && npm run test:regression:agent-actions && npm run test:regression:context-window && npm run test:registry && npm run test:router && npm run test:preflight && npm run test:gomdori",
    "eval:embeddings": "tsx tests/embeddings/embedding-eval.ts",
    "test:preflight": "tsx tests/regression/preflight-finance.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.49.4",
    "ai": "^6.0.184",
    "discord.js": "^14.19.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "express-rate-limit": "^8.5.2",
    "hono": "^4.12.27",
    "ip-address": "^10.2.0",
    "qs": "^6.15.3",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "supabase": "^2.108.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
