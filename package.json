{
  "name": "muel-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "mcp:discord": "tsx src/mcpServer.ts",
    "mcp:discord:start": "node dist/mcpServer.js",
    "typecheck": "tsc --noEmit",
    "typecheck:edge": "cd supabase/functions && deno task check",
    "test:regression": "tsx tests/regression/mention-llm-callsite.test.ts",
    "test:regression:research": "tsx tests/regression/research-enrich-callsite.test.ts",
    "test:regression:discord-polish": "tsx tests/regression/discord-output-polish.test.ts",
    "test:regression:agent-actions": "tsx tests/regression/agent-capability-actions.test.ts",
    "test:registry": "tsx tests/registry/registry.smoke.test.ts",
    "test:router": "tsx tests/router/router.smoke.test.ts",
    "test:gomdori": "tsx tests/gomdori/phase1-simulation.test.ts && tsx tests/gomdori/w4-runtime-contract.test.ts && tsx tests/gomdori/w6-pasua.test.ts && tsx tests/gomdori/w6-roster.test.ts && tsx tests/gomdori/codex.test.ts && tsx tests/gomdori/v2-abilities.test.ts",
    "test:smoke": "npm run test:regression && npm run test:regression:research && npm run test:regression:discord-polish && npm run test:regression:agent-actions && npm run test:registry && npm run test:router && npm run test:preflight && npm run test:gomdori",
    "eval:embeddings": "tsx tests/embeddings/embedding-eval.ts",
    "test:preflight": "tsx tests/regression/preflight-finance.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.49.4",
    "ai": "^6.0.184",
    "discord.js": "^14.19.3",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "supabase": "^2.98.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
