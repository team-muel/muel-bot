DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
YOUTUBE_DATA_API_KEY=
MUEL_AI_MODEL=gemini-2.5-flash
MUEL_CHAT_MODEL=
MUEL_ROUTER_MODEL=
MUEL_EXTRACT_MODEL=
MUEL_SUMMARY_MODEL=
MUEL_HEAVY_MODEL=
MUEL_EMBEDDING_MODEL=gemini-embedding-001
MUEL_EMBEDDING_DIMENSIONS=768
HUB_URL=https://muel-tree.vercel.app

# --- AI-Q research lane ---
# When AIQ_SERVER_URL is unset, the "이 소식 더 알아보기" button responds with
# a "backend not configured" message and no job is enqueued. Flip AIQ_ENABLED
# to "false" to hide the button entirely without removing the env.
AIQ_ENABLED=true
AIQ_SERVER_URL=
AIQ_AUTH_TOKEN=
AIQ_POLL_INTERVAL_MS=5000
AIQ_POLL_TIMEOUT_MS=1500000
AIQ_DEFAULT_AGENT_TYPE=deep_researcher
AIQ_TOPIC_MAX_CHARS=2000
