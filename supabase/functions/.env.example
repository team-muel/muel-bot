# Local environment for `supabase functions serve`.
# Copy to .env.local (which is gitignored) and fill in real values.

SUPABASE_URL=https://pqzmehtuwnxyspfhyucd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
GAME_JWT_SECRET=

# Per-Activity Discord credentials. Each Muel Activity is hosted by its own
# Discord application; auth-exchange picks credentials by activity slug.
# Add a new pair when a new Activity is added to muel-tree's activities config.

# Gomdori (Mafia game — separate Discord app, NOT the Muel Bot app)
GOMDORI_DISCORD_CLIENT_ID=
GOMDORI_DISCORD_CLIENT_SECRET=
